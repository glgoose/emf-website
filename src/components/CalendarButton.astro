---
interface Props {
  href: string;
  tooltip: string;
  ariaLabel?: string;
  class?: string;
}

const { href, tooltip, ariaLabel, class: className } = Astro.props;
---

<a
  href={href}
  class:list={['group relative inline-block text-[#111111] no-underline hover:no-underline', className]}
  aria-label={ariaLabel}
>
  <slot />
  <span
    role="tooltip"
    class="pointer-events-none absolute right-0 top-full mt-2 w-max max-w-[17rem] rounded-sm bg-[#111111] px-2 py-1 text-[0.6rem] leading-snug opacity-0 transition-opacity group-hover:opacity-100 z-10 normal-case not-italic tracking-normal"
    style="color:#fff"
  >
    {tooltip}
  </span>
</a>
