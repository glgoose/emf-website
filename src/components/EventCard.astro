---
import { formatLongDate, formatTimeRange, formatSpeakersLine } from '../lib/formatDateTime';

interface Props {
  title: string;
  date: Date;
  time: string;
  end_time?: string;
  location?: string;
  type?: string;
  speakers?: { name: string }[];
  cover?: string;
  description?: string;
  slug: string;
}

const { title, date, time, end_time, location, type, speakers, cover, description, slug } = Astro.props;

const dateFormatted = formatLongDate(date);
const timeFormatted = formatTimeRange(time, end_time);
const speakersLine = speakers && speakers.length ? formatSpeakersLine(speakers) : '';
const subline = speakersLine ? `${type} ${speakersLine}` : type;
---

<article>
  <p class="leading-[1.4]">
    <span>{dateFormatted} · {timeFormatted}</span>
    {location && <span> · {location}</span>}
  </p>
  <a href={`/activiteiten/${slug}`} class="hover:underline">
    <p class="leading-[1.4]" set:html={title} />
    {subline && <p class="leading-[1.4]">{subline}</p>}
  </a>
  {description && (
    <p class="mt-4 text-sm" set:html={description} />
  )}
</article>
