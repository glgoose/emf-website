---
import { formatLongDate, formatTimeRange, formatSpeakersLine } from '../lib/formatDateTime';

interface Props {
  title: string;
  date: Date;
  time: string;
  end_time?: string;
  location?: string;
  type?: string;
  speakers?: { name: string }[];
  cover?: string;
  description?: string;
  slug: string;
}

const { title, date, time, end_time, location, type, speakers, cover, description, slug } = Astro.props;

const dateFormatted = formatLongDate(date);
const timeFormatted = formatTimeRange(time, end_time);
const speakersLine = speakers && speakers.length ? formatSpeakersLine(speakers) : '';
const subline = speakersLine ? `${type} ${speakersLine}` : type;
---

<a href={`/activiteiten/${slug}`} class="group block">
  <article>
    <p class="leading-[1.4]">
      <span>{dateFormatted} · {timeFormatted}</span>
      {location && <span> · {location}</span>}
    </p>
    <p class="leading-[1.4] group-hover:underline underline-offset-2 decoration-[0.08em]" set:html={title} />
    {subline && <p class="leading-[1.4] group-hover:underline underline-offset-2 decoration-[0.08em]">{subline}</p>}
    {description && (
      <p class="mt-4 text-sm"><span set:html={description} /><span class="inline-block w-0 overflow-visible whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity"> &gt;&gt;</span></p>
    )}
    {cover && (
      <img src={cover} alt="" class="w-full mt-4" />
    )}
  </article>
</a>
