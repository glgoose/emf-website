---
import type { CollectionEntry } from 'astro:content';
import { formatShortDate, formatEventTime, formatSpeakersLine } from '../lib/formatDateTime';

interface Props {
  events: CollectionEntry<'events'>[];
  past?: boolean;
}

const { events, past = false } = Astro.props;
---

<ul class="list-none m-0 p-0 sm:grid sm:grid-cols-[7rem_1fr] sm:gap-x-3 sm:gap-y-2">
  {events.map(event => {
    const { title, date, time, type, location, speakers } = event.data;
    const dateFormatted = `${formatShortDate(date)}${past ? ` ${date.getFullYear()}` : ''}`;
    const timeFormatted = formatEventTime(time);
    const speakersLine = speakers && speakers.length ? formatSpeakersLine(speakers) : '';
    const subline = speakersLine ? `${type} ${speakersLine}` : type;
    const metaMobile = [dateFormatted, timeFormatted, location].filter(Boolean).join(' · ');
    return (
      <li class="contents">
        <a
          href={`/activiteiten/${event.id}`}
          class="group max-sm:block max-sm:mb-4 sm:col-span-full sm:grid sm:grid-cols-subgrid items-baseline no-underline hover:no-underline"
        >
          <span class="sm:hidden text-xs leading-snug">{metaMobile}</span>
          <span class="hidden sm:block text-xs leading-snug whitespace-nowrap">{dateFormatted} · {timeFormatted}</span>
          <span
            class="block text-base leading-snug lowercase min-w-0 group-hover:underline underline-offset-2"
            set:html={title}
          />
          {location
            ? <span class="hidden sm:block text-xs leading-snug truncate lowercase">{location}</span>
            : <span class="hidden sm:block" />
          }
          <span class="block text-xs leading-snug min-w-0">{subline}</span>
        </a>
      </li>
    );
  })}
</ul>
