---
const footerLinks = [
  { href: '/activiteiten', label: 'Activiteiten' },
  { href: '/over-emf', label: 'Over EMF' },
  { href: '/contact', label: 'Contact' },
];
---

<footer class="border-t border-[#111111] mt-16">
  <!-- Top row -->
  <div class="max-w-6xl mx-auto px-6 py-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
    <a
      href="/"
      class="text-lg uppercase tracking-tight text-[#111111] hover:no-underline"
    >
      ernest mandelfonds
    </a>
    <ul class="flex flex-wrap gap-x-6 gap-y-1 list-none m-0 p-0">
      {footerLinks.map(link => (
        <li>
          <a href={link.href} class="text-[#111111] text-sm hover:underline underline-offset-4">{link.label}</a>
        </li>
      ))}
    </ul>
  </div>

  <!-- Bottom row -->
  <div class="border-t border-[#e8e8e8]">
    <div class="max-w-6xl mx-auto px-6 py-3 text-xs text-[#555555] flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1">
      <span>© 2026 vzw Ernest Mandelfonds</span>
      <span>Inhoud beschikbaar onder <a href="https://creativecommons.org/licenses/by-sa/4.0/" class="underline hover:text-[#111111]" target="_blank" rel="noopener" aria-label="CC BY-SA 4.0 (opent in nieuw tabblad)">CC BY-SA 4.0</a>, tenzij anders aangegeven.</span>
    </div>
  </div>
</footer>
