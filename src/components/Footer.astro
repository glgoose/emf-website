---
const year = new Date().getFullYear();

const footerLinks = [
  { href: '/activiteiten', label: 'Activiteiten' },
  { href: '/over-emf', label: 'Over EMF' },
  { href: '/publicaties', label: 'Publicaties' },
  { href: '/contact', label: 'Contact' },
];
---

<footer class="bg-[#E8320A] text-white mt-16">
  <!-- Top row -->
  <div class="max-w-6xl mx-auto px-4 py-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
    <a
      href="/"
      class="font-barlow font-black text-xl uppercase tracking-tight text-white hover:no-underline"
      style="font-family:'Barlow Condensed',Arial,sans-serif;font-weight:900;"
    >
      ernest mandelfonds
    </a>
    <ul class="flex flex-wrap gap-x-6 gap-y-1 list-none m-0 p-0">
      {footerLinks.map(link => (
        <li>
          <a href={link.href} class="text-white text-sm hover:underline">{link.label}</a>
        </li>
      ))}
    </ul>
  </div>

  <!-- Divider -->
  <div class="border-t border-[#C8270A]"></div>

  <!-- Bottom row -->
  <div class="max-w-6xl mx-auto px-4 py-4 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-2 text-xs text-white/80">
    <span>BE06 0020 0994 8922 · BTW 1022.401.378 · RPR Antwerpen</span>
    <span>© {year} vzw Ernest Mandelfonds</span>
  </div>

  <!-- Copyright note -->
  <div class="border-t border-[#C8270A]">
    <div class="max-w-6xl mx-auto px-4 py-2 text-xs text-white/60">
      Inhoud beschikbaar onder <a href="https://creativecommons.org/licenses/by-sa/4.0/" class="underline hover:text-white" target="_blank" rel="noopener">CC BY-SA 4.0</a>, tenzij anders aangegeven.
    </div>
  </div>
</footer>
