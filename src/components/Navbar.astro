---
const navLinks = [
  { href: '/activiteiten', label: 'activiteiten' },
  { href: '/nieuws', label: 'nieuws' },
  { href: '/publicaties', label: 'publicaties' },
  { href: '/steun-ons', label: 'steun ons' },
];

const overEmfLinks = [
  { href: '/over-emf', label: 'over de vzw' },
  { href: '/contact', label: 'contact' },
  { href: '/colofon', label: 'colofon' },
];

interface Props {
  currentPath?: string;
  atTop?: boolean;
}

const { currentPath = '', atTop = false } = Astro.props;
---

<nav
  class:list={['w-full', atTop ? 'border-b border-[#111111] py-4' : 'border-t border-[#111111] py-4']}
  aria-label="Hoofdnavigatie"
>
  <div class="max-w-6xl mx-auto px-6">
    <ul
      class="flex flex-wrap items-baseline gap-y-1 list-none m-0 p-0"
      style="font-family:'EB Garamond',Georgia,serif;font-size:1.5rem;font-style:italic;"
    >
      {navLinks.map((link) => {
        const active = currentPath === link.href || currentPath.startsWith(link.href + '/');
        return (
          <>
            <li>
              <a
                href={link.href}
                class:list={['text-[#111111] hover:underline underline-offset-4', active && 'underline']}
              >
                {link.label}
              </a>
            </li>
            <li aria-hidden="true" class="mx-2 select-none text-[#555555]">/</li>
          </>
        );
      })}

      <!-- Over EMF dropdown -->
      <li class="relative" id="over-emf-item">
        <button
          id="over-emf-btn"
          class:list={[
            'text-[#111111] hover:underline underline-offset-4 cursor-pointer bg-transparent border-none p-0',
            (currentPath === '/over-emf' || currentPath === '/contact' || currentPath === '/colofon') && 'underline',
          ]}
          style="font-family:'EB Garamond',Georgia,serif;font-size:1.5rem;font-style:italic;"
          aria-expanded="false"
          aria-haspopup="true"
        >
          over EMF
        </button>
        <ul
          id="over-emf-menu"
          class="hidden absolute left-0 bg-white border border-[#111111] py-1 min-w-[160px] z-50 list-none m-0 p-0"
          style="font-family:'EB Garamond',Georgia,serif;font-size:1.25rem;font-style:italic;top:calc(100% + 6px);"
          role="menu"
        >
          {overEmfLinks.map(link => (
            <li role="none">
              <a
                href={link.href}
                class="block px-4 py-2 text-[#111111] hover:underline underline-offset-2"
                role="menuitem"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </li>
    </ul>
  </div>
</nav>

<script>
  const btn = document.getElementById('over-emf-btn');
  const menu = document.getElementById('over-emf-menu');
  const item = document.getElementById('over-emf-item');

  btn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
  });

  document.addEventListener('click', (e) => {
    if (!item?.contains(e.target as Node)) {
      btn?.setAttribute('aria-expanded', 'false');
      menu?.classList.add('hidden');
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      btn?.setAttribute('aria-expanded', 'false');
      menu?.classList.add('hidden');
    }
  });
</script>
