---
const navLinks = [
  { href: '/activiteiten', label: 'activiteiten' },
  { href: '/over-emf', label: 'over EMF' },
];

interface Props {
  currentPath?: string;
  atTop?: boolean;
}

const { currentPath = '', atTop = false } = Astro.props;

const overEmfPaths = ['/over-emf', '/steun-ons', '/contact', '/colofon'];
---

<nav
  class:list={[atTop ? 'border-b border-[#111111] pb-3 mb-5' : 'border-t border-[#111111] pt-3 mt-5']}
  aria-label="Hoofdnavigatie"
>
  <ul
    class="flex flex-wrap items-center gap-y-1 list-none m-0 p-0 lowercase font-['EB_Garamond',Georgia,serif] text-[1.5rem] italic"
  >
    {!atTop && (
      <>
        <li>
          <a href="/" aria-label="Ernest Mandelfonds – startpagina">
            <img src="/images/symbolBLACK.png" alt="" class="h-[1.7rem] w-auto block" />
          </a>
        </li>
        <li aria-hidden="true" class="mx-2 select-none text-[#555555]">/</li>
      </>
    )}
    {navLinks.map((link, i) => {
      const isOverEmf = link.href === '/over-emf';
      const active = isOverEmf
        ? overEmfPaths.some(p => currentPath === p || currentPath.startsWith(p + '/'))
        : currentPath === link.href || currentPath.startsWith(link.href + '/');
      return (
        <>
          <li>
            <a
              href={link.href}
              class:list={['text-[#111111] hover:underline underline-offset-4 decoration-[0.08em]', active && 'underline']}
            >
              {link.label}
            </a>
          </li>
          {i < navLinks.length - 1 && (
            <li aria-hidden="true" class="mx-2 select-none text-[#555555]">/</li>
          )}
        </>
      );
    })}
  </ul>
</nav>
