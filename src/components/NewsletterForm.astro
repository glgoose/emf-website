---
---

<form id="newsletter-form" novalidate>
  <div class="relative" style="max-width:480px;">
    <input
      id="newsletter-email"
      type="email"
      name="email"
      required
      placeholder="Inschrijven op nieuwsbrief"
      class="w-full border border-[#111111] rounded-full bg-transparent text-[#111111] outline-none placeholder:text-[#999999] placeholder:not-italic"
      style="font-family:'EB Garamond',Georgia,serif;font-size:1.125rem;padding:0.35rem 2.5rem 0.35rem 1.25rem;-webkit-appearance:none;appearance:none;"
      aria-label="E-mailadres voor nieuwsbrief"
    />
    <button
      type="submit"
      class="absolute right-4 top-1/2 -translate-y-1/2 text-[#111111] hover:opacity-50 transition-opacity bg-transparent border-none p-0 leading-none"
      style="font-family:'EB Garamond',Georgia,serif;font-size:1.125rem;"
      aria-label="Inschrijven"
    >→</button>
  </div>
  <p id="newsletter-msg" class="hidden mt-2 text-sm" aria-live="polite"></p>
</form>

<script>
  const form = document.getElementById('newsletter-form') as HTMLFormElement | null;
  const msg = document.getElementById('newsletter-msg') as HTMLParagraphElement | null;
  const emailInput = document.getElementById('newsletter-email') as HTMLInputElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!emailInput || !msg) return;

    const email = emailInput.value.trim();
    if (!email) return;

    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });

      if (res.ok) {
        msg.textContent = 'Bedankt! U bent ingeschreven.';
        msg.className = 'mt-2 text-sm text-green-700';
        form.reset();
      } else {
        const data = await res.json().catch(() => ({}));
        msg.textContent = (data as any).error || 'Er is een fout opgetreden. Probeer later opnieuw.';
        msg.className = 'mt-2 text-sm text-red-700';
      }
    } catch {
      msg.textContent = 'Netwerkfout. Controleer uw verbinding en probeer opnieuw.';
      msg.className = 'mt-2 text-sm text-red-700';
    }

    msg.classList.remove('hidden');
  });
</script>
