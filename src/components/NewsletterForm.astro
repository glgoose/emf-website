---
---

<form
  id="newsletter-form"
  novalidate
  class="mt-8"
>
  <div
    class="flex items-center border border-[#111111] rounded-full overflow-hidden pl-6 pr-2 py-2"
    style="max-width:480px;"
  >
    <input
      id="newsletter-email"
      type="email"
      name="email"
      required
      placeholder="Inschrijven op nieuwsbrief"
      class="flex-1 bg-transparent border-none outline-none text-[#111111] min-w-0"
      style="font-family:'EB Garamond',Georgia,serif;font-size:1.125rem;font-style:italic;"
      aria-label="E-mailadres voor nieuwsbrief"
    />
    <button
      type="submit"
      class="shrink-0 w-9 h-9 flex items-center justify-center rounded-full border border-[#111111] text-[#111111] hover:bg-[#111111] hover:text-white transition-colors"
      aria-label="Inschrijven"
    >
      →
    </button>
  </div>
  <p id="newsletter-msg" class="hidden mt-2 text-sm pl-6" aria-live="polite"></p>
</form>

<script>
  const form = document.getElementById('newsletter-form') as HTMLFormElement | null;
  const msg = document.getElementById('newsletter-msg') as HTMLParagraphElement | null;
  const emailInput = document.getElementById('newsletter-email') as HTMLInputElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!emailInput || !msg) return;

    const email = emailInput.value.trim();
    if (!email) return;

    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });

      if (res.ok) {
        msg.textContent = 'Bedankt! U bent ingeschreven.';
        msg.className = 'mt-2 text-sm pl-6 text-green-700';
        form.reset();
      } else {
        const data = await res.json().catch(() => ({}));
        msg.textContent = (data as any).error || 'Er is een fout opgetreden. Probeer later opnieuw.';
        msg.className = 'mt-2 text-sm pl-6 text-red-700';
      }
    } catch {
      msg.textContent = 'Netwerkfout. Controleer uw verbinding en probeer opnieuw.';
      msg.className = 'mt-2 text-sm pl-6 text-red-700';
    }

    msg.classList.remove('hidden');
  });
</script>
