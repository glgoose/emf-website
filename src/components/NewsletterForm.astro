---
import UnderlineField from './UnderlineField.astro';
---

<form id="newsletter-form" class="flex-1 min-w-0 max-w-[15em]" novalidate>
  <UnderlineField
    id="newsletter-email"
    type="email"
    name="email"
    required
    placeholder="Inschrijven voor nieuwsbrief"
    ariaLabel="E-mailadres voor nieuwsbrief"
    submitLabel=">>"
    submitAriaLabel="Inschrijven"
  />
  <p id="newsletter-msg" class="hidden mt-2 text-sm" aria-live="polite"></p>
</form>

<script>
  const form = document.getElementById('newsletter-form') as HTMLFormElement | null;
  const msg = document.getElementById('newsletter-msg') as HTMLParagraphElement | null;
  const emailInput = document.getElementById('newsletter-email') as HTMLInputElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!emailInput || !msg) return;

    const email = emailInput.value.trim();
    if (!email) return;

    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });

      if (res.ok) {
        msg.textContent = 'Bedankt! U bent ingeschreven.';
        msg.className = 'mt-2 text-sm text-green-700';
        form.reset();
      } else {
        const data = await res.json().catch(() => ({}));
        msg.textContent = (data as any).error || 'Er is een fout opgetreden. Probeer later opnieuw.';
        msg.className = 'mt-2 text-sm text-red-700';
      }
    } catch {
      msg.textContent = 'Netwerkfout. Controleer uw verbinding en probeer opnieuw.';
      msg.className = 'mt-2 text-sm text-red-700';
    }

    msg.classList.remove('hidden');
  });
</script>
