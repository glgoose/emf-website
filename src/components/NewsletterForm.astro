---
---

<section class="w-full border-t border-[#111111] py-10 mt-12">
  <div class="max-w-6xl mx-auto px-6">
    <form
      id="newsletter-form"
      class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3"
      novalidate
    >
      <input
        id="newsletter-email"
        type="email"
        name="email"
        required
        placeholder="uw@emailadres.be"
        class="flex-1 border border-[#111111] rounded-full px-6 py-3 focus:outline-none focus:ring-2 focus:ring-[#E8320A] focus:ring-offset-1 text-[#111111] bg-white"
        style="font-family:'EB Garamond',Georgia,serif;font-size:1.125rem;"
        aria-label="E-mailadres voor nieuwsbrief"
      />
      <button
        type="submit"
        class="border border-[#111111] rounded-full px-8 py-3 text-[#111111] bg-white hover:bg-[#111111] hover:text-white transition-colors whitespace-nowrap flex items-center justify-center gap-3"
        style="font-family:'EB Garamond',Georgia,serif;font-size:1.125rem;font-style:italic;"
      >
        Inschrijven op nieuwsbrief
        <span aria-hidden="true">→</span>
      </button>
    </form>
    <p id="newsletter-msg" class="hidden mt-3 text-sm" aria-live="polite"></p>
  </div>
</section>

<script>
  const form = document.getElementById('newsletter-form') as HTMLFormElement | null;
  const msg = document.getElementById('newsletter-msg') as HTMLParagraphElement | null;
  const emailInput = document.getElementById('newsletter-email') as HTMLInputElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!emailInput || !msg) return;

    const email = emailInput.value.trim();
    if (!email) return;

    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });

      if (res.ok) {
        msg.textContent = 'Bedankt! U bent ingeschreven op de nieuwsbrief.';
        msg.className = 'mt-3 text-sm text-green-700';
        form.reset();
      } else {
        const data = await res.json().catch(() => ({}));
        msg.textContent = (data as any).error || 'Er is een fout opgetreden. Probeer later opnieuw.';
        msg.className = 'mt-3 text-sm text-red-700';
      }
    } catch {
      msg.textContent = 'Netwerkfout. Controleer uw verbinding en probeer opnieuw.';
      msg.className = 'mt-3 text-sm text-red-700';
    }

    msg.classList.remove('hidden');
  });
</script>
