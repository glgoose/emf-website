---
interface Props {
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  [key: string]: unknown;
}

const { href, type = 'button', class: extraClass, ...rest } = Astro.props;
const base = 'inline-flex items-center gap-2 border border-[#111111] rounded-full text-[#111111] hover:bg-[#111111] hover:text-white transition-colors no-underline hover:no-underline text-lg py-[0.2em] px-4';
---

{href
  ? <a href={href} class:list={[base, extraClass]} {...rest}><slot /></a>
  : <button type={type} class:list={[base, extraClass]} {...rest}><slot /></button>
}
