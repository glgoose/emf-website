---
import UnderlineField from './UnderlineField.astro';

interface Props {
  eventSlug: string;
  eventTitle: string;
  registrationDeadline?: Date;
}

const { eventSlug, eventTitle, registrationDeadline } = Astro.props;

const deadlineFormatted = registrationDeadline
  ? registrationDeadline.toLocaleDateString('nl-BE', { day: 'numeric', month: 'long', year: 'numeric' })
  : null;
---

<section class="mt-6">
  <!-- Toggle button -->
  <button
    id="reg-toggle"
    type="button"
    class="text-lg text-[#111111] hover:underline underline-offset-2 bg-transparent border-none p-0 cursor-pointer"
    aria-expanded="false"
    aria-controls="reg-panel"
  >
    inschrijven <span id="reg-toggle-icon" class="not-italic">+</span>
  </button>

  {deadlineFormatted && (
    <p class="text-sm text-[#555555] mt-1">Inschrijven kan tot {deadlineFormatted}.</p>
  )}

  <!-- Collapsible form -->
  <div id="reg-panel" class="hidden mt-2">
    <form id="reg-form" class="space-y-4 max-w-lg" novalidate>
      <input type="hidden" name="event_slug" value={eventSlug} />
      <input type="hidden" name="event_title" value={eventTitle} />

      <UnderlineField id="reg-naam" type="text" name="naam" required placeholder="Naam" />

      <UnderlineField
        id="reg-email"
        type="email"
        name="email"
        required
        placeholder="E-mail"
        submitLabel=">>"
        submitAriaLabel="Inschrijven"
      />

      <p id="reg-msg" class="text-sm hidden" aria-live="polite"></p>
    </form>
  </div>
</section>

<script>
  const toggle = document.getElementById('reg-toggle');
  const panel = document.getElementById('reg-panel');
  const icon = document.getElementById('reg-toggle-icon');

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    panel?.classList.toggle('hidden');
    if (icon) icon.textContent = expanded ? '+' : '−';
  });

  const form = document.getElementById('reg-form') as HTMLFormElement | null;
  const msg = document.getElementById('reg-msg') as HTMLParagraphElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !msg) return;

    const data = Object.fromEntries(new FormData(form).entries());

    if (!String(data.naam ?? '').trim()) {
      msg.textContent = 'Vul uw naam in.';
      msg.className = 'text-sm text-red-700';
      msg.classList.remove('hidden');
      return;
    }
    if (!String(data.email ?? '').trim()) {
      msg.textContent = 'Vul uw e-mailadres in.';
      msg.className = 'text-sm text-red-700';
      msg.classList.remove('hidden');
      return;
    }

    try {
      const res = await fetch('/api/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        msg.textContent = 'Uw inschrijving is ontvangen. We nemen contact op voor bevestiging.';
        msg.className = 'text-sm text-green-700';
        form.reset();
        // Collapse after success
        toggle?.setAttribute('aria-expanded', 'false');
        panel?.classList.add('hidden');
        if (icon) icon.textContent = '+';
      } else {
        const json = await res.json().catch(() => ({}));
        msg.textContent = (json as any).error || 'Er is een fout opgetreden. Probeer later opnieuw.';
        msg.className = 'text-sm text-red-700';
      }
    } catch {
      msg.textContent = 'Netwerkfout. Controleer uw verbinding en probeer opnieuw.';
      msg.className = 'text-sm text-red-700';
    }

    msg.classList.remove('hidden');
  });
</script>
