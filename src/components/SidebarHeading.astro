---
interface Props {
  backHref: string;
  title: string;
  subtitle?: string;
  eventSubtitle?: string;
  large?: boolean;
}

const { backHref, title, subtitle, large = false } = Astro.props;
---

<div class="border-t-[2px] border-[#111111] pt-0.5">
  <hgroup class="mb-4 group">
    <h1 class:list={['text-[1.25rem] leading-[1.25] font-bold lowercase break-words [hyphens:auto]', large && 'text-[1.4rem]']}><a
      href={backHref}
      class="inline-block w-0 overflow-visible whitespace-nowrap mr-1.5 text-[0.75em] font-normal opacity-0 group-hover:opacity-100 transition-opacity no-underline hover:no-underline hover:text-[#111111] [direction:rtl]"
      aria-label="Terug"
    >&gt;&gt;</a><span set:html={title} /></h1>
    {subtitle && (
      <p class="mt-[0.3em] text-[1rem] leading-[1.25] text-[#555555] font-normal italic lowercase">
        {subtitle}
      </p>
    )}
  </hgroup>
  <slot />
</div>
