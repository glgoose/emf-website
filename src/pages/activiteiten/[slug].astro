---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SidebarHeading from '../../components/SidebarHeading.astro';
import RegistrationForm from '../../components/RegistrationForm.astro';
import AddToCalendarDropdown from '../../components/AddToCalendarDropdown.astro';
import { Picture, getImage } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import { formatLongDate, formatTimeRange, formatSpeakersLine, stripHtml } from '../../lib/formatDateTime';

const coverImages = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/images/events/*',
  { eager: true },
);

export async function getStaticPaths() {
  const events = await getCollection('events');
  return events.map(event => ({
    params: { slug: event.id },
    props: { event },
  }));
}

const { event } = Astro.props;
const { Content } = await render(event);

const {
  title,
  subtitle,
  date,
  time,
  type,
  location,
  address,
  speakers,
  registration_open,
  registration_deadline,
  cover,
  cover_filter,
  price,
  end_time,
} = event.data;

const dateFormatted = formatLongDate(date);
const timeFormatted = formatTimeRange(time, end_time);
const speakersLine = speakers && speakers.length ? formatSpeakersLine(speakers) : '';
const subline = speakersLine ? `${type} ${speakersLine}` : type;

const today = new Date();
today.setHours(0, 0, 0, 0);
const isPast = date < today;

const segments = Astro.url.pathname.split('/').filter(Boolean);
const parentPath = segments.length <= 1 ? '/' : '/' + segments.slice(0, -1).join('/');

const plainTitle = stripHtml(title);

const siteBase = Astro.site ?? 'https://ernestmandelfonds.org';
const filename = cover?.split('/').pop();
const coverMeta = filename
  ? coverImages[`../../assets/images/events/${filename}`]?.default
  : undefined;
const ogImageObj = coverMeta
  ? await getImage({ src: coverMeta, width: 1200, format: 'jpeg', quality: 85 })
  : undefined;
const ogImage = ogImageObj ? new URL(ogImageObj.src, siteBase).toString() : undefined;
const canonicalURL = new URL(Astro.url.pathname, siteBase).toString();

const dateStr = date.toISOString().split('T')[0];
const startDate = `${dateStr}T${time}`;
const endDate = end_time ? `${dateStr}T${end_time}` : undefined;

const eventStructuredData: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: plainTitle,
  startDate,
  ...(endDate && { endDate }),
  description: event.data.description,
  url: canonicalURL,
  ...(ogImage && { image: ogImage }),
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  ...(location && {
    location: {
      '@type': 'Place',
      name: location,
      ...(address && { address }),
    },
  }),
  organizer: {
    '@type': 'Organization',
    name: 'vzw Ernest Mandelfonds',
    url: new URL('/', siteBase).toString(),
  },
  ...(speakers && speakers.length > 0 && {
    performer: speakers.map(s => ({ '@type': 'Person', name: s.name })),
  }),
};
---

<BaseLayout title={plainTitle} description={event.data.description} ogImage={ogImage}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(eventStructuredData)} />
  </Fragment>
  <Fragment slot="aside">
    <SidebarHeading
      backHref={parentPath}
      title={title}
      subtitle={subtitle}
    >
      <p class="mt-[0.3em] text-[1rem] leading-[1.25] text-[#555555] font-normal italic lowercase mb-4">{subline}</p>
      <p class="text-xs leading-snug mb-0">{dateFormatted}</p>
      <p class="text-xs leading-snug mb-2">{timeFormatted}</p>
      {location && (
        <p class="text-xs leading-snug mb-2">
          {location}
          {address && <><br />{address}</>}
        </p>
      )}
      {price && (
        <p class="text-xs leading-snug mt-1">{price}</p>
      )}
      <AddToCalendarDropdown
        event={event}
        icsHref={`/activiteiten/${event.id}.ics`}
        class="mt-2"
      />
    </SidebarHeading>
  </Fragment>

  {coverMeta && (
    <Picture
      src={coverMeta}
      alt={plainTitle}
      formats={['avif', 'webp']}
      widths={[400, 700, 1000, 1400]}
      sizes="(min-width: 1024px) 700px, 100vw"
      class="w-full mb-6"
      style={cover_filter ? `filter: ${cover_filter}` : undefined}
    />
  )}

  <article class="prose">
    <Content />
  </article>

  {speakers && speakers.length > 0 && (
    <section class="prose mb-6">
      <h3>Bio</h3>
      <ul>
        {speakers.map(s => (
          <li>
            <strong>{s.name}</strong>{(() => {
              const bio = Array.isArray(s.bio) ? s.bio.join(', ') : (s.bio ?? '');
              return bio ? <Fragment>: <span set:html={bio} /></Fragment> : null;
            })()}
          </li>
        ))}
      </ul>
    </section>
  )}

  {registration_open && !isPast && (
    <RegistrationForm
      eventSlug={event.id}
      eventTitle={plainTitle}
      registrationDeadline={registration_deadline}
    />
  )}
</BaseLayout>
