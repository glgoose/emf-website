---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allEvents = await getCollection('events');
const sorted = allEvents.sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

const today = new Date();
today.setHours(0, 0, 0, 0);

const upcoming = sorted.filter(e => e.data.date >= today);
const past = sorted.filter(e => e.data.date < today).reverse();
---

<BaseLayout title="Activiteiten" description="Overzicht van activiteiten en evenementen van Ernest Mandelfonds.">
  <div class="max-w-6xl mx-auto px-6 py-12">

    <div class="lg:grid lg:grid-cols-[14rem_1fr] lg:gap-12 lg:items-start">
      <!-- Sticky title column -->
      <div class="lg:sticky lg:top-10 mb-8 lg:mb-0">
        <h1
          class="font-barlow font-black text-3xl lowercase border-t-[2px] border-[#111111] pt-3 mb-4"
          style="font-family:'Barlow Condensed',Arial,sans-serif;font-weight:900;"
        >
          Activiteiten
        </h1>
        <a href="/" class="text-xs text-[#555555] hover:underline underline-offset-2">← startpagina</a>
      </div>

      <!-- Content column -->
      <div class="border-t-[2px] border-[#111111] pt-0">

        {upcoming.length > 0 && (
          <section class="mb-10">
            <h2 class="text-xs uppercase tracking-widest text-[#555555] py-3 border-b border-[#e8e8e8] mb-0">
              Komende activiteiten
            </h2>
            <ul class="list-none m-0 p-0">
              {upcoming.map(event => {
                const dateStr = event.data.date.toLocaleDateString('nl-BE', {
                  day: 'numeric', month: 'long', year: 'numeric'
                });
                return (
                  <li class="border-b border-[#e8e8e8]">
                    <a
                      href={`/activiteiten/${event.id}`}
                      class="flex items-baseline gap-4 py-3 hover:bg-[#f8f8f8] px-1 -mx-1 group"
                    >
                      <span class="text-xs text-[#555555] shrink-0 w-36">{dateStr}</span>
                      <span class="text-sm font-bold text-[#111111] group-hover:underline underline-offset-2 leading-snug">
                        {event.data.title}
                      </span>
                      {event.data.location && <span class="text-xs text-[#555555] ml-auto shrink-0 hidden sm:block">{event.data.location}</span>}
                    </a>
                  </li>
                );
              })}
            </ul>
          </section>
        )}

        {upcoming.length === 0 && (
          <p class="text-sm text-[#555555] py-6 border-b border-[#e8e8e8]">Er zijn momenteel geen geplande activiteiten.</p>
        )}

        {past.length > 0 && (
          <section class="mt-10">
            <h2 class="text-xs uppercase tracking-widest text-[#555555] py-3 border-b border-[#e8e8e8] mb-0">
              Voorbije activiteiten
            </h2>
            <ul class="list-none m-0 p-0">
              {past.map(event => {
                const dateStr = event.data.date.toLocaleDateString('nl-BE', {
                  day: 'numeric', month: 'long', year: 'numeric'
                });
                return (
                  <li class="border-b border-[#e8e8e8]">
                    <a
                      href={`/activiteiten/${event.id}`}
                      class="flex items-baseline gap-4 py-2 hover:bg-[#f8f8f8] px-1 -mx-1 group"
                    >
                      <span class="text-xs text-[#555555] shrink-0 w-36">{dateStr}</span>
                      <span class="text-sm text-[#555555] group-hover:underline underline-offset-2 leading-snug">
                        {event.data.title}
                      </span>
                    </a>
                  </li>
                );
              })}
            </ul>
          </section>
        )}

      </div>
    </div>
  </div>
</BaseLayout>
