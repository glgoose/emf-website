---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EventList from '../../components/EventList.astro';
import SidebarHeading from '../../components/SidebarHeading.astro';
import CalendarButton from '../../components/CalendarButton.astro';
import CalendarSubscribeIcon from '../../components/icons/CalendarSubscribeIcon.astro';
import { getCollection } from 'astro:content';

const allEvents = await getCollection('events');
const sorted = allEvents.sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

const today = new Date();
today.setHours(0, 0, 0, 0);

const upcoming = sorted.filter(e => e.data.date >= today);
const past = sorted.filter(e => e.data.date < today).reverse();

const calendarHost = import.meta.env.DEV
  ? Astro.url.host
  : (Astro.site ?? new URL('https://ernestmandelfonds.org')).host;
const calendarHref = `webcal://${calendarHost}/activiteiten/kalender.ics`;
---

<BaseLayout title="Activiteiten" description="Overzicht van activiteiten en evenementen van Ernest Mandelfonds.">
  <Fragment slot="aside">
    <>
      <a
        href="/"
        class="lg:hidden block text-[0.75em] leading-none font-normal no-underline hover:no-underline hover:text-[#111111] mb-1"
        aria-label="Terug"
      >&lt;&lt;</a>
      <div class="border-t-[2px] border-[#111111] pt-0.5">
        <div class="flex items-center justify-between lg:block mb-4">
          <h1 class="text-[1.25rem] leading-[1.25] font-bold lowercase break-words [hyphens:auto]">
            <a
              href="/"
              class="hidden lg:inline-block w-0 overflow-visible whitespace-nowrap lg:mr-1.5 text-[0.75em] font-normal opacity-0 group-hover:opacity-100 transition-opacity no-underline hover:no-underline hover:text-[#111111] [direction:rtl]"
              aria-label="Terug"
            >&gt;&gt;</a>Activiteiten
          </h1>
          <CalendarButton
            href={calendarHref}
            tooltip="Abonneer je op onze nieuwe activiteiten"
            ariaLabel="Abonneer op de agenda"
            class="shrink-0 ml-4 lg:ml-0 lg:mt-2"
          >
            <CalendarSubscribeIcon />
          </CalendarButton>
        </div>
      </div>
    </>
  </Fragment>

  <div>
    {upcoming.length > 0 ? (
      <section>
        <EventList events={upcoming} />
      </section>
    ) : (
      <p class="text-sm">Er zijn momenteel geen geplande activiteiten.</p>
      )}

    {past.length > 0 && (
      <section class="mt-8">
        <h2 class="mb-3">
          Voorbije activiteiten
        </h2>
        <EventList events={past} past/>
      </section>
    )}
  </div>
</BaseLayout>
