---
import BaseLayout from '../layouts/BaseLayout.astro';
import SidebarNav from '../components/SidebarNav.astro';
import DefinitionList from '../components/DefinitionList.astro';
import { overEmfNavItems } from '../data/overEmfNav.ts';
---

<BaseLayout title="Colofon" description="Colofon, cookiebeleid en juridische informatie van Ernest Mandelfonds.">
  <Fragment slot="aside">
    <SidebarNav
      backHref="/"
      sectionLabel="Over EMF"
      sectionHref="/over-emf"
      currentPage="colofon"
      navItems={overEmfNavItems}
    />
  </Fragment>

  <div class="space-y-14">
    <section>
      <p>Website ontwikkelt door Glenn Goossens.</p>
    </section>

    <section>
      <h2 id="copyright" class="text-[1.1rem] leading-[1.3] font-bold normal-case border-b border-[#e8e8e8] pb-2 mb-4">Copyright</h2>
      <div class="[&_p]:leading-relaxed">
        <p>
          © 2026 vzw Ernest Mandelfonds. Alle inhoud op deze website is, tenzij anders
          aangegeven, beschikbaar onder de 
          <a href="https://creativecommons.org/licenses/by-sa/4.0/" target="_blank" rel="noopener" class="underline-offset-2">
            Creative Commons (BY-SA 4.0) licentie
          </a>.
        </p>
        <p>
          Dit betekent dat u de inhoud vrij mag delen en bewerken, mits u de bron vermeldt
          en uw bijdragen onder dezelfde licentie verspreidt.
        </p>
      </div>
    </section>

    <section>
      <h2 id="cookiebeleid" class="text-[1.1rem] leading-[1.3] font-bold normal-case border-b border-[#e8e8e8] pb-2 mb-4">Cookiebeleid</h2>
      <div class="[&_p]:leading-relaxed">
        <p>
          Wij gebruiken geen cookies :)
        </p>
      </div>
    </section>

    <section>
      <h2 id="juridisch" class="text-[1.1rem] leading-[1.3] font-bold normal-case border-b border-[#e8e8e8] pb-2 mb-4">Juridische informatie</h2>
      <div class="[&_p]:leading-relaxed">
        <p>
          Deze website wordt beheerd door vzw Ernest Mandelfonds, een vereniging zonder winstoogmerk naar Belgisch recht.
        </p>
        <DefinitionList class="text-sm gap-x-8 mt-4 [&_dt]:text-left [&_dd]:text-[#555555]">
          <dt>maatschappelijke zetel</dt>
          <dd>Violetstraat 39/a, 2060 Antwerpen</dd>
          <dt>BTW</dt>
          <dd>1022.401.378</dd>
          <dt>RPR</dt>
          <dd>Antwerpen</dd>
          <dt>rekening</dt>
          <dd>BE06 0020 0994 8922</dd>
          <dt>e-mail</dt>
          <dd><a href="mailto:info@ernestmandelfonds.be" class="underline underline-offset-2">info@ernestmandelfonds.be</a></dd>
        </DefinitionList>
      </div>
    </section>
  </div>
</BaseLayout>
