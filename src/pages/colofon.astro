---
import BaseLayout from '../layouts/BaseLayout.astro';
import SidebarNav from '../components/SidebarNav.astro';
import DefinitionList from '../components/DefinitionList.astro';
import Email from '../components/Email.astro';
import { overEmfNavItems } from '../data/overEmfNav.ts';
---

<BaseLayout title="Colofon" description="Colofon, cookiebeleid en juridische informatie van Ernest Mandelfonds.">
  <Fragment slot="aside">
    <SidebarNav
      backHref="/"
      sectionLabel="Over EMF"
      sectionHref="/over-emf"
      currentPage="colofon"
      navItems={overEmfNavItems}
    />
  </Fragment>

  <div class="space-y-6">
    <section>
      <p>Website ontwikkelt door Glenn Goossens.</p>
      <p>Design in samenwerking met <a href="https://ccroissant.be/" target="_blank" rel="noopener">ccroissant studio</a>.</p>
    </section>

    <section>
      <h3 id="copyright">Copyright</h3>
      <p>
        © 2026 vzw Ernest Mandelfonds. Alle inhoud op deze website is, tenzij anders
        aangegeven, beschikbaar onder de
        <a href="https://creativecommons.org/licenses/by-sa/4.0/" target="_blank" rel="noopener">
          Creative Commons (BY-SA 4.0) licentie
        </a>.
      </p>
      <p>
        Dit betekent dat u de inhoud vrij mag delen en bewerken, mits u de bron vermeldt
        en uw bijdragen onder dezelfde licentie verspreidt.
      </p>
    </section>

    <section>
      <h3 id="cookiebeleid">Cookiebeleid</h3>
      <p>Wij gebruiken geen cookies :)</p>
    </section>

    <section>
      <h3 id="juridisch">Juridische informatie</h3>
      <p>
        Deze website wordt beheerd door vzw Ernest Mandelfonds, een vereniging zonder winstoogmerk naar Belgisch recht.
      </p>
      <DefinitionList class="text-sm gap-x-8 mt-4">
        <dt>maatschappelijke zetel</dt>
        <dd>Violetstraat 39/a, 2060 Antwerpen</dd>
        <dt>BTW</dt>
        <dd>1022.401.378</dd>
        <dt>RPR</dt>
        <dd>Antwerpen</dd>
        <dt>rekening</dt>
        <dd>BE06 0020 0994 8922</dd>
        <dt>e-mail</dt>
        <dd><Email address="info@ernestmandelfonds.be" class="underline underline-offset-2" /></dd>
      </DefinitionList>
    </section>
  </div>
</BaseLayout>
