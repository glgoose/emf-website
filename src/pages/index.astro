---
import BaseLayout from '../layouts/BaseLayout.astro';
import EventCard from '../components/EventCard.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import PillButton from '../components/PillButton.astro';
import { getCollection } from 'astro:content';

const today = new Date();
today.setHours(0, 0, 0, 0);

const allEvents = await getCollection('events');
const upcomingEvents = allEvents
  .filter(e => e.data.date >= today)
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

const nextEvent = upcomingEvents[0] ?? null;
---

<BaseLayout isHomepage={true}>
  <Fragment slot="aside">
    <a href="/" aria-label="Ernest Mandelfonds – startpagina">
      <img
        src="/images/symbolPINK.png"
        alt="Ernest Mandelfonds"
        class="lg:ml-auto block max-w-[80px]"
      />
    </a>
  </Fragment>

  {nextEvent && (
    <section>
      <h2>
        Volgende activiteit
      </h2>
      <EventCard
        title={nextEvent.data.title}
        date={nextEvent.data.date}
        time={nextEvent.data.time}
        location={nextEvent.data.location ?? undefined}
        end_time={nextEvent.data.end_time}
        type={nextEvent.data.type}
        speakers={nextEvent.data.speakers}
        cover={nextEvent.data.cover}
        description={nextEvent.data.description}
        slug={nextEvent.id}
      />
    </section>
  )}

  <div class="flex flex-wrap items-center justify-between gap-4 mt-10">
    <PillButton href="/steun-ons" class="shrink-0">Steun ons</PillButton>
    <NewsletterForm />
  </div>
</BaseLayout>
