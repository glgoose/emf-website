---
import BaseLayout from '../layouts/BaseLayout.astro';
import EventCard from '../components/EventCard.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import { getCollection } from 'astro:content';

const today = new Date();
today.setHours(0, 0, 0, 0);

const allEvents = await getCollection('events');
const upcomingEvents = allEvents
  .filter(e => e.data.date >= today)
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

const nextEvent = upcomingEvents[0] ?? null;

const allPosts = await getCollection('posts');
const latestPosts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout isHomepage={true}>
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="lg:grid lg:grid-cols-[14rem_1fr] lg:gap-12 lg:items-start">

      <!-- Left: logo -->
      <div class="mb-8 lg:mb-0">
        <a href="/" aria-label="Ernest Mandelfonds – startpagina">
          <img
            src="/images/logoRED.png"
            alt="Ernest Mandelfonds"
            class="w-full max-w-[160px]"
          />
        </a>
      </div>

      <!-- Right: content -->
      <div>
        {nextEvent && (
          <section class="mb-12">
            <h2
              class="font-barlow font-black text-xs uppercase tracking-widest text-[#555555] mb-4"
              style="font-family:'Barlow Condensed',Arial,sans-serif;font-weight:700;"
            >
              Volgende activiteit
            </h2>
            <EventCard
              title={nextEvent.data.title}
              date={nextEvent.data.date}
              time={nextEvent.data.time}
              location={nextEvent.data.location}
              description={nextEvent.data.description}
              slug={nextEvent.id}
            />
          </section>
        )}

        <section>
          <h2
            class="font-barlow font-black text-xs uppercase tracking-widest text-[#555555] mb-4"
            style="font-family:'Barlow Condensed',Arial,sans-serif;font-weight:700;"
          >
            Nieuws &amp; publicaties
          </h2>
          <ul class="list-none m-0 p-0 space-y-4">
            {latestPosts.map(post => {
              const dateStr = post.data.date.toLocaleDateString('nl-BE', {
                day: 'numeric', month: 'long', year: 'numeric'
              });
              return (
                <li class="border-t border-[#e8e8e8] pt-4">
                  <p class="text-xs text-[#555555] mb-1">{dateStr}</p>
                  <a
                    href={`/publicaties#${post.id}`}
                    class="text-[#111111] font-bold text-sm hover:underline leading-snug"
                  >
                    {post.data.title}
                  </a>
                </li>
              );
            })}
          </ul>
          <div class="mt-6">
            <a href="/publicaties" class="text-sm text-[#E8320A] font-bold hover:underline">Alle publicaties →</a>
          </div>
        </section>
      </div>

    </div>
  </div>

  <NewsletterForm />
</BaseLayout>
