---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SidebarNav from '../../components/SidebarNav.astro';
import DefinitionList from '../../components/DefinitionList.astro';
import Email from '../../components/Email.astro';
import { overEmfNavItems } from '../../data/overEmfNav.ts';
---

<BaseLayout title="Kameraden" description="Partnerorganisaties en solidariteitsverbanden van Ernest Mandelfonds.">
  <Fragment slot="aside">
    <SidebarNav
      backHref="/over-emf"
      sectionLabel="Over EMF"
      sectionHref="/over-emf"
      currentPage="kameraden"
      navItems={overEmfNavItems}
    />
  </Fragment>

  <div>
    <div>
      <h2 class="mb-2">Organisaties</h2>
      <DefinitionList leftWidth="10rem">
        <dt><a href="https://www.facebook.com/p/Antwerpse-Coalitie-voor-Palestina-61570118911226/" target="_blank" rel="noopener noreferrer">Antwerpse Coalitie voor Palestina</a></dt>
        <dd>coalitie waar het Ernest Mandelfonds deel van uitmaakt</dd>
        <dt><a href="https://www.sap-rood.org" target="_blank" rel="noopener noreferrer">SAP</a></dt>
        <dd>Antikapitalisten</dd>
        <dt><a href="https://fourth.international/en/166" target="_blank" rel="noopener noreferrer">Vierde Internationale</a></dt>
        <dd>internationale revolutionair-socialistische organisatie</dd>
        <dt><a href="https://www.iire.org/nl" target="_blank" rel="noopener noreferrer">IIRE</a></dt>
        <dd>International Institute for Research and Education</dd>
      </DefinitionList>
      <h2 class="mt-8 mb-2">Publicaties</h2>
      <DefinitionList leftWidth="10rem">
        <dt><a href="https://inprecor.fr/" target="_blank" rel="noopener noreferrer">Inprecor</a></dt>
        <dd>Franstalig maandblad van de Vierde Internationale</dd>
        <dt><a href="https://internationalviewpoint.org/" target="_blank" rel="noopener noreferrer">International Viewpoint</a></dt>
        <dd>Engelstalige website van de Vierde Internationale</dd>
        <dt><a href="http://www.marxists.org/nederlands/index.htm" target="_blank" rel="noopener noreferrer">Marxistisch Internet Archief</a></dt>
        <dd>online archief van Nederlandstalige marxistische teksten</dd>
        <dt><a href="http://www.uitpers.be/" target="_blank" rel="noopener noreferrer">Uitpers</a></dt>
        <dd>webzine voor internationale politiek</dd>
        <dt><a href="https://www.inprekorr.de/" target="_blank" rel="noopener noreferrer">Die Internationale</a></dt>
        <dd>Duitstalig magazine</dd>
        <dt><a href="https://florsnieuweblog.blogspot.com/2025/09/kijk-waarop-ik-onverwachts-in-mijn.html" target="_blank" rel="noopener noreferrer">De Laatste Vuurtorenwachter</a></dt>
        <dd>blog van Flor Vandekerckhove, over <em>Uitgelezen Moorden: Een sociale geschiedenis van het misdaadverhaal</em> door Ernest Mandel.</dd>
      </DefinitionList>
      <p class="mt-10 prose">
        De vermelde organisaties en publicaties zijn partijen waarmee we hetzij banden hebben, hetzij verwantschap voelen.
      </p>
      <p class="prose">
        Indien er linken zijn die niet werken of als u vindt dat er een website aan ontbreekt, kan u dat altijd melden via
        <Email address="info@ernestmandelfonds.org" />.
      </p>
    </div>
  </div>
</BaseLayout>
