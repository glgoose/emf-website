---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

const allPosts = await getCollection('posts');
const sorted = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const postsWithContent = await Promise.all(
  sorted.map(async post => {
    const { Content } = await render(post);
    return { post, Content };
  })
);
---

<BaseLayout title="Publicaties" description="Teksten, analyses en standpunten van Ernest Mandelfonds.">
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="lg:grid lg:grid-cols-[14rem_1fr] lg:gap-12 lg:items-start">

      <!-- Sticky left: title -->
      <div class="lg:sticky lg:top-10 mb-8 lg:mb-0 border-t-[2px] border-[#111111] pt-3">
        <h1
          class="font-barlow font-black text-2xl lowercase mb-6"
          style="font-family:'Barlow Condensed',Arial,sans-serif;font-weight:900;"
        >
          Publicaties
        </h1>
        <a href="/" class="text-xs text-[#555555] hover:underline underline-offset-2">← startpagina</a>
      </div>

      <!-- Content column -->
      <div class="border-t-[2px] border-[#111111] pt-6">

        {sorted.length === 0 && (
          <p class="text-sm text-[#555555]">Er zijn nog geen publicaties beschikbaar.</p>
        )}

        <ul class="list-none m-0 p-0 space-y-14">
          {postsWithContent.map(({ post, Content }) => {
            const dateStr = post.data.date.toLocaleDateString('nl-BE', {
              day: 'numeric', month: 'long', year: 'numeric'
            });
            return (
              <li id={post.id} class="scroll-mt-10">
                <p class="text-xs text-[#555555] uppercase tracking-wide mb-1">{dateStr}</p>
                <h2
                  class="font-barlow font-black text-2xl sm:text-3xl leading-tight mb-3 lowercase"
                  style="font-family:'Barlow Condensed',Arial,sans-serif;font-weight:900;"
                >
                  {post.data.title}
                </h2>
                <p class="text-sm text-[#555555] mb-4 italic">{post.data.summary}</p>
                <div class="prose prose-lg max-w-none text-[#111111] [&_p]:leading-relaxed [&_a]:underline [&_a]:underline-offset-2">
                  <Content />
                </div>
              </li>
            );
          })}
        </ul>

      </div>
    </div>
  </div>
</BaseLayout>
