---
import BaseLayout from '../layouts/BaseLayout.astro';
import SidebarNav from '../components/SidebarNav.astro';
import DefinitionList from '../components/DefinitionList.astro';
import { overEmfNavItems } from '../data/overEmfNav.ts';
---

<BaseLayout title="Steun ons" description="Steun de werking van vzw Ernest Mandelfonds.">
  <Fragment slot="aside">
    <SidebarNav
      backHref="/"
      sectionLabel="Over EMF"
      sectionHref="/over-emf"
      currentPage="steun-ons"
      navItems={overEmfNavItems}
    />
  </Fragment>

  <div class="[&_p]:leading-relaxed">
    <div>
      <p>
        Zoals iedereen weet, kost koken helaas ook geld. De vzw Ernest Mandelfonds beschikt niet over subsidies of andere reguliere inkomstenbronnen.
      </p>
      <p>
        Als je onze werking wil ondersteunen, kan je hier een gift doen:
      </p>
      <DefinitionList class="mt-4 my-5">
        <dt class="font-bold">rekeningnummer</dt>
        <dd>BE06 0020 0994 8922</dd>
        <dt class="font-bold">begunstigde</dt>
        <dd>vzw Ernest Mandelfonds</dd>
        <dt class="font-bold">mededeling</dt>
        <dd><em>gift</em></dd>
      </DefinitionList>
    </div>
  </div>
</BaseLayout>
